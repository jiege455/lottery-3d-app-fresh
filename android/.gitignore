# This file ignores build artifacts and temporary files

# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Signing configuration
key.properties

# IntelliJ
*.iml
.idea/
out/

# Keystore files
*.jks
*.keystore

# External native build folder
.externalNativeBuild

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# Android Profiling
*.hprof

# Misc
*.log
*.tmp
.DS_Store
Thumbs.db
